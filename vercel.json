{
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": "dist/public",
  "framework": null,

  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/products", "destination": "/products/index.html" },
    { "source": "/applications", "destination": "/applications/index.html" },
    { "source": "/case-studies", "destination": "/case-studies/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/resources", "destination": "/resources/index.html" },
    { "source": "/downloads", "destination": "/downloads/index.html" },
    { "source": "/industries", "destination": "/industries/index.html" }
  ],

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
